<div class="mx-auto max-w-7xl px-4 py-6">
  <div class="mb-6 flex items-center justify-between">
    <h1 class="text-2xl font-bold">テーマ管理</h1>
    <span class="text-sm text-base-content/60">全 <%= @themes.total_count %> 件</span>
  </div>

  <div class="card bg-base-100 shadow-lg ring-1 ring-base-300">
    <div class="card-body p-0">
      <% if @themes.empty? %>
        <p class="p-6 text-center text-base-content/60">テーマはありません</p>
      <% else %>
        <div class="overflow-x-auto">
          <table class="table table-zebra">
            <thead>
              <tr>
                <th>ID</th>
                <th>タイトル</th>
                <th>投稿者</th>
                <th>カテゴリ</th>
                <th>ステータス</th>
                <th>投票数</th>
                <th>投稿日</th>
                <th></th>
              </tr>
            </thead>
            <tbody>
              <% @themes.each do |theme| %>
                <tr>
                  <td class="text-sm text-base-content/60"><%= theme.id %></td>
                  <td class="max-w-xs">
                    <p class="truncate font-medium"><%= theme.title %></p>
                  </td>
                  <td class="text-sm"><%= theme.user.nickname.presence || theme.user.email %></td>
                  <td>
                    <span class="badge badge-sm badge-ghost">
                      <%= Theme.human_attribute_name("category/#{theme.category}") %>
                    </span>
                  </td>
                  <td>
                    <% badge_class = case theme.status
                                     when "considering" then "badge-warning"
                                     when "confirmed"   then "badge-info"
                                     when "done"        then "badge-success"
                                     else                    "badge-ghost"
                                     end %>
                    <span class="badge badge-sm <%= badge_class %>">
                      <%= Theme.human_attribute_name("status/#{theme.status}") %>
                    </span>
                  </td>
                  <td><%= theme.theme_votes_count %></td>
                  <td class="text-sm text-base-content/60">
                    <%= l(theme.created_at, format: :short) %>
                  </td>
                  <td>
                    <%= link_to "詳細", admin_theme_path(theme), class: "btn btn-ghost btn-xs" %>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>

        <div class="flex justify-center p-4">
          <%= paginate @themes %>
        </div>
      <% end %>
    </div>
  </div>
</div>
